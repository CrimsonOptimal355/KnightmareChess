{
  "version": 8,
  "configurePresets": [
    {
      "name": "mingw-debug",
      "displayName": "MinGW Debug",
      "description": "Configure Chess with MinGW-w64 and SFML 3.1.0 bundled in external/.",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_COMPILER": "C:/mingw64/bin/g++.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "SFML_DIR": "${sourceDir}/external/SFML-3.1.0/lib/cmake/SFML"
      }
    },
    {
      "name": "mingw-release",
      "displayName": "MinGW Release",
      "description": "Configure Chess with MinGW-w64 in Release mode.",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "C:/mingw64/bin/g++.exe",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "SFML_DIR": "${sourceDir}/external/SFML-3.1.0/lib/cmake/SFML"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "mingw-debug",
      "configurePreset": "mingw-debug"
    },
    {
      "name": "mingw-release",
      "configurePreset": "mingw-release"
    }
  ]
}